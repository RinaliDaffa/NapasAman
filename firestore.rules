rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Saved locations — users can only access their own data
    match /saved_locations/{locationId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // Alert thresholds — users can only access their own data
    match /alert_thresholds/{thresholdId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // Alert history — users can only access their own data
    match /alert_history/{historyId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
  }
}
